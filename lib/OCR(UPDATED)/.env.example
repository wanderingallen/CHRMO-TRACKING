# ─────────────────────────────────────────────────────────────
# CHRMO Document Tracking System — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to version control.

# Environment: development | production
ENVIRONMENT=production

# ── Database ──
DB_HOST=localhost
DB_NAME=chrmo_db
DB_USER=your_db_user
DB_PASS=your_db_password
DB_PORT=3306

# ── Security Keys (generate random strings for production!) ──
# Generate with: php -r "echo bin2hex(random_bytes(32));"
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_64_HEX_STRING
FILE_ENC_KEY=CHANGE_ME_GENERATE_ANOTHER_64_HEX_STRING

# RBAC: set to false in production once user roles are configured
ALLOW_ADMIN_FALLBACK=false
ADMIN_EMAILS=

# ── SMTP / Email ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME=CHRMO Document Tracking
SMTP_ENCRYPTION=tls

# ── reCAPTCHA (optional) ──
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
ENABLE_RECAPTCHA=false
